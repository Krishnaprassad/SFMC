<script runat="server">
  Platform.Load("core",
"1.1.1");

  /* ══════════════════════════════════════════════════════════════════
     EO Asset Script Activity  (v5 — Text Extract)
     ────────────────────────────────────────────────────────────────
     CHANGES IN v5:
       1. Extracts PLAIN TEXT instead of HTML content.
       2. Checks views.text.content first (SFMC native text view).
       3. Falls back to stripping HTML tags if text view is absent.
       4. WSProxy fallback uses TextBody instead of HTMLBody.
       5. stripHtmlToText() helper converts HTML → readable plain text.
     ────────────────────────────────────────────────────────────────
     PREREQUISITES:
       - All non-PK fields in the Log DE MUST be Nullable.
       - Log_ID MUST be the Primary Key in the Log DE.
       - Asset_Name MUST be the Primary Key in the Data DE.
       - Content field MUST be nvarchar(max) (created in Email Studio
         with a BLANK length).
  ══════════════════════════════════════════════════════════════════ */
/* ── 0. Configuration ──────────────────────────────────────────── */
  var AUTH_URL       = "https://mcxdf19724mz1blcrm78fnsn5w21.auth.marketingcloudapis.com/v2/token";
  var REST_BASE      = "https://mcxdf19724mz1blcrm78fnsn5w21.rest.marketingcloudapis.com";
  var CLIENT_ID      = "3udrkn0y9k3yxgge4vu1x4vb";
  var CLIENT_SECRET  = "ObuzdthdR3GdrUCKktvQOd1d";

  /* ── IMPORTANT: Use the EXTERNAL KEY of each DE, NOT the name ── */
  var DE_DATA_EXTKEY = "46F03A89-6C67-4459-B3E1-1FAC849768D6"; // EO_Asset_Script_Activity_Updated
  var DE_LOG_EXTKEY  = "6949E722-3710-445D-9D1B-0EB4CD735F37"; // EO_Asset_Script_Activity_Log

  /* DE name — used for Platform.Function calls */
  var DE_DATA_NAME   = "EO_Asset_Script_Activity_Updated";

  var SEARCH_PATTERN = "Message_Cente";
  var MAX_PAGES      = 20;
  var PAGE_SIZE      = 50;

  /* ── Log counter for unique IDs ────────────────────────────────── */
  var logCounter   = 0;
  var runTimestamp = Now();

  /* Simple run ID from timestamp */
  var d     = new Date();
  var runId = "" + d.getFullYear()
    + ("0" + (d.getMonth() + 1)).slice(-2)
    + ("0" + d.getDate()).slice(-2)
    + ("0" + d.getHours()).slice(-2)
    + ("0" + d.getMinutes()).slice(-2)
    + ("0" + d.getSeconds()).slice(-2);

  /* ── Helper: get response body from HTTP.Post() ────────────────── */
  function getResponseBody(resp) {
    if (!resp) return "";
    if (typeof resp == "string") return resp;
    if (resp.Response && resp.Response.length > 0) return resp.Response[
        0
    ].toString();
    return Stringify(resp);
}
/* ── Helper: write a log row using Core Library Rows.Add() ─────── */
  function writeLog(level, stepName, message, detail, assetsProcessed) {
    logCounter++;
    var logId = runId + "_" + logCounter;

    var logDE = DataExtension.Init(DE_LOG_EXTKEY);
    logDE.Rows.Add({
      Log_ID:           logId,
      Run_Timestamp:    runTimestamp,
      Log_Level:        level    || "INFO",
      Step_Name:        stepName || "UNKNOWN",
      Message:          message  ? message.toString().substring(0,
        4000) : "N/A",
      Detail:           detail   ? detail.toString().substring(0,
        4000)  : "N/A",
      Assets_Processed: (assetsProcessed != null) ? assetsProcessed : 0
    });
}
/* ── Helper: insert a row into the Data DE ──────────────────────── */
  function insertAsset(assetName, assetId, customerKey, subject, contentText) {
    var dataDE = DataExtension.Init(DE_DATA_EXTKEY);
    dataDE.Rows.Add({
      Asset_Name:        assetName   || "N/A",
      Asset_ID:          assetId     || "N/A",
      Customer_Key:      customerKey || "N/A",
      Subject:           subject     || "N/A",
      Content:           contentText || "N/A",
      Last_Updated_Date: Now()
    });
}
/* ══════════════════════════════════════════════════════════════════
     Helper: stripHtmlToText(html)
     ────────────────────────────────────────────────────────────────
     Converts an HTML string into readable plain text by:
       1. Replacing block-level tags with newlines for readability.
       2. Replacing <br> variants with a single newline.
       3. Removing all remaining HTML tags.
       4. Decoding common HTML entities.
       5. Collapsing excessive whitespace and blank lines.
  ══════════════════════════════════════════════════════════════════ */
  function stripHtmlToText(html) {
    if (!html) return "";

    var text = html;

    /* ── 1. Replace block-level elements with newlines ─────────────
       Process these BEFORE stripping tags so structure is preserved. */
    /* Paragraph / div / section end → double newline */
    text = text.split("</p>").join("\n\n");
    text = text.split("</P>").join("\n\n");
    text = text.split("</div>").join("\n");
    text = text.split("</DIV>").join("\n");
    text = text.split("</tr>").join("\n");
    text = text.split("</TR>").join("\n");
    text = text.split("</li>").join("\n");
    text = text.split("</LI>").join("\n");
    text = text.split("</h1>").join("\n\n");
    text = text.split("</h2>").join("\n\n");
    text = text.split("</h3>").join("\n\n");
    text = text.split("</h4>").join("\n\n");
    text = text.split("</h5>").join("\n\n");
    text = text.split("</h6>").join("\n\n");
    text = text.split("</H1>").join("\n\n");
    text = text.split("</H2>").join("\n\n");
    text = text.split("</H3>").join("\n\n");
    text = text.split("</H4>").join("\n\n");
    text = text.split("</H5>").join("\n\n");
    text = text.split("</H6>").join("\n\n");
    text = text.split("</blockquote>").join("\n");

    /* ── 2. Replace <br> variants with newline ───────────────────── */
    text = text.split("<br>").join("\n");
    text = text.split("<BR>").join("\n");
    text = text.split("<br/>").join("\n");
    text = text.split("<BR/>").join("\n");
    text = text.split("<br />").join("\n");
    text = text.split("<BR />").join("\n");

    /* ── 3. Remove <style> … </style> blocks entirely ───────────── */
    var styleStart = text.indexOf("<style");
    while (styleStart > -1) {
      var styleEnd = text.indexOf("</style>", styleStart);
      if (styleEnd > -1) {
        text = text.substring(0, styleStart) + text.substring(styleEnd + 8);
        } else {
        break; /* malformed — stop to avoid infinite loop */
        }
      styleStart = text.indexOf("<style");
    }
    /* ── 4. Remove <script> … </script> blocks entirely ─────────── */
    var scriptStart = text.indexOf("<script");
    while (scriptStart > -1) {
      var scriptEnd = text.indexOf("</script>", scriptStart);
      if (scriptEnd > -1) {
        text = text.substring(0, scriptStart) + text.substring(scriptEnd + 9);
        } else {
        break;
        }
      scriptStart = text.indexOf("<script");
    }
    /* ── 5. Strip all remaining HTML tags with a simple loop ───────
       SSJS does not support RegExp.replace with callbacks, so we
       manually find and remove each tag.                            */
    var result  = "";
    var inTag   = false;
    var len     = text.length;
    for (var idx = 0; idx < len; idx++) {
      var ch = text.charAt(idx);
      if (ch === "<") {
        inTag = true;
        } else if (ch === ">") {
        inTag = false;
        } else if (!inTag) {
        result += ch;
        }
    }
    text = result;

    /* ── 6. Decode common HTML entities ─────────────────────────── */
    text = text.split("&nbsp;").join(" ");
    text = text.split("&amp;").join("&");
    text = text.split("&lt;").join("<");
    text = text.split("&gt;").join(">");
    text = text.split("&quot;").join('"');
    text = text.split("&#39;").join("'");
    text = text.split("&ldquo;").join('"');
    text = text.split("&rdquo;").join('"');
    text = text.split("&lsquo;").join("'");
    text = text.split("&rsquo;").join("'");
    text = text.split("&mdash;").join("—");
    text = text.split("&ndash;").join("–");
    text = text.split("&hellip;").join("...");
    text = text.split("&copy;").join("©");
    text = text.split("&reg;").join("®");
    text = text.split("&trade;").join("™");

    /* ── 7. Collapse runs of spaces/tabs on each line ────────────── */
    var lines    = text.split("\n");
    var cleaned  = [];
    var blankRun = 0;
    for (var li = 0; li < lines.length; li++) {
        /* collapse multiple spaces/tabs to a single space */
      var line = "";
      var prevSpace = false;
      for (var ci = 0; ci < lines[li
        ].length; ci++) {
        var c = lines[li
            ].charAt(ci);
        if (c === " " || c === "\t" || c === "\r") {
          if (!prevSpace) { line += " "; prevSpace = true;
                }
            } else {
          line += c;
          prevSpace = false;
            }
        }
      line = line.replace(/^\s+|\s+$/g,
        ""); /* trim leading/trailing */

      if (line === "") {
        blankRun++;
        if (blankRun <= 1) cleaned.push(""); /* allow at most 1 blank line */
        } else {
        blankRun = 0;
        cleaned.push(line);
        }
    }

    return cleaned.join("\n").replace(/^\s+|\s+$/g,
    ""); /* final trim */
}
/* ══════════════════════════════════════════════════════════════════
     MAIN EXECUTION
  ══════════════════════════════════════════════════════════════════ */
/* ── STEP 0: Sanity check — can we write to the Log DE? ────────── */
  writeLog("INFO",
"SCRIPT_START",
"Script Activity started (TEXT mode). Run ID: " + runId,
"Full overwrite mode — plain text content will be extracted.",
0);

  try {
    /* ── STEP 0.5: Clear all existing rows from the Data DE ──────── */
    var clearProxy  = new Script.Util.WSProxy();
    var clearResult = clearProxy.performItem("DataExtension",
    { CustomerKey: DE_DATA_EXTKEY
    },
    "ClearData");

    var clearStatus = (clearResult && clearResult.Status) ? clearResult.Status : "Unknown";
    writeLog("INFO",
    "DE_CLEARED",
    "Cleared Data DE before full reload.",
    "ClearData status: " + clearStatus,
    0);

    /* ── STEP 1: Get OAuth2 Access Token ─────────────────────────── */
    var authPayload = '{
        "grant_type": "client_credentials",
        "client_id":"'
      + CLIENT_ID + '","client_secret":"' + CLIENT_SECRET + '"}';

    var authResp = HTTP.Post(AUTH_URL,
        "application/json", authPayload);

    if (!authResp || !authResp.Response || authResp.Response.length == 0) {
      throw "AUTH_FAIL: No response from token endpoint.";
        }

    var authBody    = Platform.Function.ParseJSON(authResp.Response[
            0
        ]);
    var accessToken = authBody.access_token;

    if (!accessToken) {
      throw "AUTH_FAIL: No access_token. Raw: " + authResp.Response[
                0
            ];
        }

    writeLog("INFO",
        "AUTH_SUCCESS",
        "OAuth2 token acquired.",
        "Token length: " + accessToken.length,
        0);

    /* ── STEP 2: Query Content Builder ───────────────────────────── */
    var totalAssetsProcessed = 0;
    var currentPage  = 1;
    var hasMorePages = true;

    while (hasMorePages && currentPage <= MAX_PAGES) {

      var queryJson = '{
                "query": {
                    "property": "name",
                    "simpleOperator": "like",
                    "value":"'
        + SEARCH_PATTERN + '%"},"page":{"page":' + currentPage
        + ',
                    "pageSize":' + PAGE_SIZE + '
                },
                "fields": []
            }';

      writeLog("INFO",
            "QUERY_PAGE_" + currentPage,
            "Sending Content Builder query.",
            "Payload: " + queryJson,
            0);

      var req = new Script.Util.HttpRequest(REST_BASE + "/asset/v1/content/assets/query");
      req.emptyContentHandling = 0;
      req.retries = 2;
      req.continueOnError = true;
      req.contentType = "application/json";
      req.setHeader("Authorization",
            "Bearer " + accessToken);
      req.postData = queryJson;
      req.method = "POST";
      var httpResp = req.send();

      var queryBodyStr = String(httpResp.content);

      writeLog("INFO",
            "QUERY_RESP_" + currentPage,
            "Response received.",
        queryBodyStr ? queryBodyStr.substring(0,
            2000) : "EMPTY",
            0);

      if (!queryBodyStr || queryBodyStr == "") {
        writeLog("WARN",
                "QUERY_EMPTY",
                "Empty response on page " + currentPage,
                "Stopping pagination.",
                0);
        hasMorePages = false;
        break;
            }

      var qBody = Platform.Function.ParseJSON(queryBodyStr);

      if (qBody && qBody.message && !qBody.items) {
        throw "CB_API_ERROR: " + qBody.message
          + (qBody.errorcode ? " [code:" + qBody.errorcode + "]": "");
            }

      var itemCount  = (qBody && qBody.items) ? qBody.items.length : 0;
      var totalCount = (qBody && qBody.count)  ? qBody.count        : 0;

      writeLog("INFO",
            "QUERY_COUNTS_" + currentPage,
            "Items this page: " + itemCount + " | Total matching: " + totalCount,
            "N/A",
            0);

      if (itemCount == 0) {
        writeLog("INFO",
                "QUERY_DONE",
                "No more assets. Pages queried: " + currentPage,
                "N/A",
                0);
        hasMorePages = false;
        break;
            }
            /* ── STEP 3: Process each asset ──────────────────────────── */
      for (var i = 0; i < qBody.items.length; i++) {
        var asset = qBody.items[i
                ];

        var assetName   = asset.name        ? asset.name.toString()        : "";
        var assetId     = asset.id          ? asset.id.toString()          : "";
        var customerKey = asset.customerKey ? asset.customerKey.toString() : "";
        var subject     = "";
        var contentText = ""; /* ← plain text (replaces contentHtml) */

        var fullAsset = null;
        try {
          var detailReq = new Script.Util.HttpRequest(
            REST_BASE + "/asset/v1/content/assets/" + assetId);
          detailReq.emptyContentHandling = 0;
          detailReq.retries = 2;
          detailReq.continueOnError = true;
          detailReq.contentType = "application/json";
          detailReq.setHeader("Authorization",
                    "Bearer " + accessToken);
          detailReq.method = "GET";
          var detailResp = detailReq.send();
          var detailStr  = String(detailResp.content);

          if (detailStr && detailStr != "") {
            fullAsset = Platform.Function.ParseJSON(detailStr);

            /* Extract Subject from possible locations */
            if (fullAsset.views && fullAsset.views.subjectline &&
                fullAsset.views.subjectline.content) {
              subject = fullAsset.views.subjectline.content;
                        } else if (fullAsset.metaData && fullAsset.metaData.subject) {
              subject = fullAsset.metaData.subject;
                        } else if (fullAsset.data && fullAsset.data.email &&
                       fullAsset.data.email.legacy &&
                       fullAsset.data.email.legacy.subject) {
              subject = fullAsset.data.email.legacy.subject;
                        } else if (fullAsset.channels && fullAsset.channels.email &&
                       fullAsset.channels.email.subject) {
              subject = fullAsset.channels.email.subject;
                        }
                        /* Log the asset structure for debugging */
            var viewKeys = [];
            if (fullAsset.views) {
              for (var vk in fullAsset.views) {
                if (fullAsset.views.hasOwnProperty(vk)) viewKeys.push(vk);
                            }
                        }
            writeLog("INFO",
                        "ASSET_STRUCTURE",
                        "Asset: " + assetName + " | assetType: " +
                (fullAsset.assetType ? Stringify(fullAsset.assetType) : "N/A"),
                        "views keys: [" + viewKeys.join(",") + "]", totalAssetsProcessed);

            /* ═══════════════════════════════════════════════════════
               TEXT EXTRACTION STRATEGY
               ─────────────────────────────────────────────────────
               Priority order:
               1. views.text.content       — SFMC native text version
               2. views.text.slots blocks  — text blocks in template
               3. Strip HTML from views.html (slot blocks or skeleton)
               4. Strip HTML from fullAsset.content (direct property)
               ═══════════════════════════════════════════════════════ */
                        /* ── PRIORITY 1 & 2: Check views.text (native text view) ── */
            if (fullAsset.views && fullAsset.views.text) {
              var textView = fullAsset.views.text;

              /* Collect text from slot blocks first (template emails) */
              var allTextContent = "";
              var textSlotCount  = 0;

              if (textView.slots) {
                for (var tSlotKey in textView.slots) {
                  if (textView.slots.hasOwnProperty(tSlotKey)) {
                    textSlotCount++;
                    var tSlotObj = textView.slots[tSlotKey
                                        ];

                    if (tSlotObj.blocks) {
                      for (var tBlockKey in tSlotObj.blocks) {
                        if (tSlotObj.blocks.hasOwnProperty(tBlockKey)) {
                          var tBlock = tSlotObj.blocks[tBlockKey
                                                    ];
                          if (tBlock.content) {
                            allTextContent += tBlock.content + "\n\n";
                                                    }
                                                    /* Nested slots */
                          if (tBlock.slots) {
                            for (var tNslotKey in tBlock.slots) {
                              if (tBlock.slots.hasOwnProperty(tNslotKey)) {
                                var tNslot = tBlock.slots[tNslotKey
                                                                ];
                                if (tNslot.blocks) {
                                  for (var tNblockKey in tNslot.blocks) {
                                    if (tNslot.blocks.hasOwnProperty(tNblockKey)) {
                                      var tNblock = tNslot.blocks[tNblockKey
                                                                            ];
                                      if (tNblock.content) {
                                        allTextContent += tNblock.content + "\n\n";
                                                                            }
                                                                        }
                                                                    }
                                                                }
                                if (tNslot.content) {
                                  allTextContent += tNslot.content + "\n\n";
                                                                }
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                    if (tSlotObj.content && !tSlotObj.blocks) {
                      allTextContent += tSlotObj.content + "\n\n";
                                        }
                                    }
                                }
                            }

              if (textSlotCount > 0 && allTextContent) {
                                /* Template-based email: text from slot blocks */
                contentText = allTextContent;
                            } else if (textView.content) {
                                /* Freeform email or direct text view content */
                contentText = textView.content;
                            }
                        }
                        /* ── PRIORITY 3: No text view — strip HTML from html view ─ */
            if (!contentText || contentText === "") {
              if (fullAsset.views && fullAsset.views.html) {
                var htmlView = fullAsset.views.html;

                var allBlockHtml = "";
                var slotCount    = 0;

                if (htmlView.slots) {
                  for (var slotKey in htmlView.slots) {
                    if (htmlView.slots.hasOwnProperty(slotKey)) {
                      slotCount++;
                      var slotObj = htmlView.slots[slotKey
                                            ];

                      if (slotObj.blocks) {
                        for (var blockKey in slotObj.blocks) {
                          if (slotObj.blocks.hasOwnProperty(blockKey)) {
                            var block = slotObj.blocks[blockKey
                                                        ];
                            if (block.content) {
                              allBlockHtml += block.content;
                                                        } else if (block.design) {
                              allBlockHtml += block.design;
                                                        }
                            if (block.slots) {
                              for (var nestedSlotKey in block.slots) {
                                if (block.slots.hasOwnProperty(nestedSlotKey)) {
                                  var nestedSlot = block.slots[nestedSlotKey
                                                                    ];
                                  if (nestedSlot.blocks) {
                                    for (var nestedBlockKey in nestedSlot.blocks) {
                                      if (nestedSlot.blocks.hasOwnProperty(nestedBlockKey)) {
                                        var nestedBlock = nestedSlot.blocks[nestedBlockKey
                                                                                ];
                                        if (nestedBlock.content) {
                                          allBlockHtml += nestedBlock.content;
                                                                                }
                                                                            }
                                                                        }
                                                                    }
                                  if (nestedSlot.content) {
                                    allBlockHtml += nestedSlot.content;
                                                                    }
                                                                }
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                      if (slotObj.content && !slotObj.blocks) {
                        allBlockHtml += slotObj.content;
                                            }
                                        }
                                    }
                                }

                var rawHtml = (slotCount > 0 && allBlockHtml)
                  ? allBlockHtml
                  : (htmlView.content ? htmlView.content : "");

                contentText = stripHtmlToText(rawHtml);
                            }
                        }
                        /* ── PRIORITY 4: Fallback — direct content property ───── */
            if (!contentText || contentText === "") {
              if (fullAsset.views && fullAsset.views.preheader &&
                  fullAsset.views.preheader.content) {
                contentText = stripHtmlToText(fullAsset.views.preheader.content);
                            } else if (fullAsset.content) {
                contentText = stripHtmlToText(fullAsset.content.toString());
                            }
                        }
                        /* If the text view content also contained HTML, strip it */
            if (contentText && contentText.indexOf("<") > -1) {
              contentText = stripHtmlToText(contentText);
                        }
                    }
                } catch (detailEx) {
          writeLog("WARN",
                    "DETAIL_FAIL",
                    "Could not fetch full details for asset: " + assetName,
                    "Error: " + Stringify(detailEx), totalAssetsProcessed);
                }
                /* Debug: log extraction result */
        writeLog("INFO",
                "CONTENT_DEBUG",
                "Asset: " + assetName + " | Type: " +
            (fullAsset ? (fullAsset.assetType ? fullAsset.assetType.name : "unknown") : "N/A"),
                "TextLen: " + (contentText ? contentText.length : 0) +
            " | Source: " + (fullAsset && fullAsset.views && fullAsset.views.text
              ? "views.text": "html-stripped"),
          totalAssetsProcessed);

        /* Truncate to 12000 chars (Content field must be nvarchar(max) in Email Studio) */
        if (contentText && contentText.length > 12000) {
          contentText = contentText.substring(0,
                    12000);
                }
                /* ── STEP 4: Insert asset into Data DE ─────────────────────── */
        insertAsset(assetName, assetId, customerKey, subject, contentText);
        totalAssetsProcessed++;

        writeLog("INFO",
                "INSERT_OK",
                "Inserted: " + assetName,
                "ID=" + assetId + " | Key=" + customerKey + " | Subject=" + subject
            + " | ModifiedDate=" + (fullAsset && fullAsset.modifiedDate
              ? fullAsset.modifiedDate : "N/A"),
          totalAssetsProcessed);
            }
            /* ── Pagination ───────────────────────────────────────────── */
      if (currentPage * PAGE_SIZE >= totalCount) {
        hasMorePages = false;
            } else {
        currentPage++;
            }
        }
        /* ── STEP 5: WSProxy fallback for legacy Email objects ────────── */
        /* Uses TextBody instead of HTMLBody to get plain text directly    */
    var prox = new Script.Util.WSProxy();
    var wsFilter = {
      Property: "Name",
      SimpleOperator: "like",
      Value: SEARCH_PATTERN + "%"
        };
    var wsResult = prox.retrieve("Email",
        [
            "ID",
            "Name",
            "CustomerKey",
            "Subject",
            "TextBody",
            "HTMLBody",
            "ModifiedDate"
        ],
      wsFilter);

    var wsCount = (wsResult && wsResult.Results) ? wsResult.Results.length : 0;
    writeLog("INFO",
        "WSPROXY_RESULT",
        "WSProxy found " + wsCount + " legacy email(s).",
        "N/A",
        0);

    if (wsCount > 0) {
      for (var j = 0; j < wsResult.Results.length; j++) {
        var em = wsResult.Results[j
                ];

        var emName        = em.Name        ? em.Name.toString()        : "";
        var emId          = em.ID          ? em.ID.toString()          : "";
        var emCustomerKey = em.CustomerKey ? em.CustomerKey.toString() : "";
        var emSubject     = em.Subject     ? em.Subject.toString()     : "";

        /* Prefer TextBody; fall back to stripping HTMLBody */
        var emContent = "";
        if (em.TextBody && em.TextBody.toString() !== "") {
          emContent = em.TextBody.toString();
                } else if (em.HTMLBody) {
          emContent = stripHtmlToText(em.HTMLBody.toString());
                }
                /* Truncate to 12000 chars */
        if (emContent && emContent.length > 12000) {
          emContent = emContent.substring(0,
                    12000);
                }

        insertAsset(emName, emId, emCustomerKey, emSubject, emContent);
        totalAssetsProcessed++;

        var emModDate = em.ModifiedDate ? em.ModifiedDate.toString() : "N/A";
        writeLog("INFO",
                "WSPROXY_INSERT",
                "Legacy email inserted: " + emName,
                "ID=" + emId + " | Key=" + emCustomerKey + " | ModifiedDate=" + emModDate,
          totalAssetsProcessed);
            }
        }
        /* ── STEP 6: Final summary ───────────────────────────────────── */
    writeLog("INFO",
        "SCRIPT_COMPLETE",
        "Finished (TEXT mode). Total assets: " + totalAssetsProcessed,
        "Run ID: " + runId, totalAssetsProcessed);
    } catch (ex) {
        /* Log the error, then re-throw so Automation shows FAILED */
    try {
      writeLog("ERROR",
            "SCRIPT_FATAL",
            "Script failed.",
            "Error: " + Stringify(ex),
            0);
        } catch (logFail) {
            /* nothing we can do */
        }
    throw ex;
    }
</script>
